# Copy to .env for local development:  cp .env.example .env
# For self-hosted PRODUCTION (TrueNAS + Cloudflare Tunnel) use .env.prod.example instead
# (cp .env.prod.example .env) with docker-compose.prod.yml — see README "Deployment".

# --- Postgres ---
POSTGRES_DB=bbtracker
POSTGRES_USER=bbtracker
POSTGRES_PASSWORD=bbtracker

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me-please
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_URL=postgres://bbtracker:bbtracker@db:5432/bbtracker
REDIS_URL=redis://redis:6379/0
# Origins allowed to POST (CSRF) and call the API (CORS) — the SvelteKit dev server:
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- MinIO / progress-photo storage (Phase 4) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Backend → MinIO over the compose network. "memory" backend is for tests only.
DIARY_STORAGE_BACKEND=s3
DIARY_S3_ENDPOINT=http://minio:9000
DIARY_S3_BUCKET=bbtracker-media

# --- Frontend (SvelteKit server-side calls to Django within the compose network) ---
BACKEND_ORIGIN=http://backend:8000

# --- Home Assistant notifications (optional) ---
# Leave blank in dev unless testing against a reachable HA instance.
# HA_BASE_URL=http://192.168.1.10:8123
# HA_TOKEN=your-long-lived-token
# HA_NOTIFY_SERVICE=notify
