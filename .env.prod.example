# ============================================================================
# BBTracker — PRODUCTION environment (TrueNAS SCALE + Cloudflare Tunnel)
#
#   cp .env.prod.example .env        # on the server, then edit the CHANGE_ME values
#   docker compose -f docker-compose.prod.yml up -d --build
#
# Consumed by docker-compose.prod.yml. Never commit your filled-in .env.
# ============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
# Generate a long random key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_long_random_secret

# Public hostname served via the Cloudflare Tunnel. `backend` + localhost are needed
# for internal SSR / container health calls.
DJANGO_ALLOWED_HOSTS=bbtracker.example.com,backend,localhost,127.0.0.1
# Must be the exact https origin (used for CSRF + cookies):
CSRF_TRUSTED_ORIGINS=https://bbtracker.example.com
CORS_ALLOWED_ORIGINS=https://bbtracker.example.com

# HTTPS is terminated at the Cloudflare edge and Caddy sets X-Forwarded-Proto=https,
# so Django already knows requests are secure. Django's own HTTP->HTTPS redirect is
# left OFF (0) so internal SSR traffic (frontend -> backend over http) isn't
# redirected; enable Cloudflare "Always Use HTTPS" at the edge instead. `check
# --deploy` will then report only security.W008 — that is expected.
DJANGO_SECURE_SSL_REDIRECT=0

# --- Postgres (internal) --- keep PASSWORD and DATABASE_URL in sync ---
POSTGRES_DB=bbtracker
POSTGRES_USER=bbtracker
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DATABASE_URL=postgres://bbtracker:CHANGE_ME_strong_db_password@db:5432/bbtracker

# --- Redis (internal) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (internal private object storage for progress photos) ---
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
DIARY_STORAGE_BACKEND=s3
DIARY_S3_ENDPOINT=http://minio:9000
DIARY_S3_BUCKET=bbtracker-media

# --- Frontend (SvelteKit / adapter-node) ---
# SSR -> Django over the internal compose network:
BACKEND_ORIGIN=http://backend:8000
# Public origin (https). adapter-node uses this to validate request origins:
PUBLIC_ORIGIN=https://bbtracker.example.com

# --- Home Assistant notifications (optional; personal self-hosted) ---
# The reminder worker posts to your HA instance for rest-timer + dose reminders.
# Leave HA_TOKEN blank to disable (every notification becomes a silent no-op).
HA_BASE_URL=http://192.168.1.10:8123
HA_TOKEN=CHANGE_ME_home_assistant_long_lived_token
# "notify" targets the default service; or a specific one e.g. mobile_app_<device>
HA_NOTIFY_SERVICE=notify

# --- Reverse proxy (Caddy) ---
# Host port Caddy publishes; point your existing cloudflared ingress at
# http://<nas-ip>:${CADDY_HTTP_PORT}. AVOID ports already in use on the NAS
# (e.g. 32400, 3000, 81, 444). 8080 is a safe default.
CADDY_HTTP_PORT=8080

# --- Optional ---
# GUNICORN_WORKERS=3
# Run idempotent reference-data seeds on backend boot (set to 1 for the first deploy):
RUN_SEED=0
